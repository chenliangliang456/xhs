# 在 Vercel 项目 Settings → Environment Variables 中配置

JWT_SECRET=请改为随机长字符串
ENCRYPT_KEY=请改为32字符以上密钥

AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_API_KEY=sk-你的密钥
AI_API_MODEL=deepseek-chat

IMAGE_GEN_API_BASE_URL=https://你的API网关地址
IMAGE_GEN_API_KEY=你的API密钥

VITE_API_PREFIX=/_/backend/api
VITE_ASSET_PREFIX=/_/backend
