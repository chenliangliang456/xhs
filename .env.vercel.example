# 在 Vercel 项目 Settings → Environment Variables 中配置

JWT_SECRET=请改为随机长字符串
ENCRYPT_KEY=请改为32字符以上密钥

# ---------- DeepSeek（文案 + GPT 思考模式）----------
AI_API_URL=https://api.deepseek.com
AI_API_KEY=sk-你的DeepSeek密钥
AI_API_MODEL=deepseek-chat

# ---------- apimart（批量生图 + GPT 开放生图）----------
IMAGE_GEN_API_BASE_URL=https://api.apimart.ai
IMAGE_GEN_API_KEY=sk-你的apimart密钥

# GPT 思考模式（留空则复用 DeepSeek）
GPT_OPEN_CHAT_URL=https://api.deepseek.com
GPT_OPEN_CHAT_API_KEY=
GPT_OPEN_CHAT_MODEL=deepseek-chat

# GPT 开放生图（留空则复用 IMAGE_GEN）
GPT_OPEN_IMAGE_API_BASE_URL=
GPT_OPEN_IMAGE_API_KEY=
GPT_OPEN_IMAGE_MODEL=gpt-image-2

VITE_API_PREFIX=/_/backend/api
VITE_ASSET_PREFIX=/_/backend
