# 在 Vercel 项目 Settings → Environment Variables 中配置（Production / Preview 均建议填写）

# --- 必填 ---
JWT_SECRET=请改为随机长字符串
ENCRYPT_KEY=请改为32字符以上密钥

# --- AI 文案 ---
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_API_KEY=sk-你的密钥

# --- AI 文生图 ---
IMAGE_GEN_API_BASE_URL=https://你的API网关地址
IMAGE_GEN_API_KEY=你的API密钥

# --- 发布（Vercel 上无法使用 Playwright 浏览器发帖，请设为 mock 或 api）---
XHS_PUBLISH_MODE=mock

# --- 若前后端分域部署，在前端 Build 变量中设置 ---
# VITE_API_ORIGIN=https://你的后端域名
