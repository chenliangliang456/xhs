{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install && npm install --prefix backend --ignore-scripts && npm install --prefix frontend",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/uploads/(.*)", "destination": "/api/index.js" },
    { "source": "/materials/((?:a|b|c)/.*)", "destination": "/api/index.js" },
    { "source": "/((?!api/|uploads/|materials/[abc]/).*)", "destination": "/index.html" }
  ]
}
