PORT=3002
JWT_SECRET=请改成你自己的随机密钥_至少32位
ENCRYPT_KEY=请改成你自己的随机密钥_至少32位

# ---------- DeepSeek（文案 + GPT 思考模式）----------
AI_API_URL=https://api.deepseek.com
AI_API_KEY=sk-你的DeepSeek密钥
AI_API_MODEL=deepseek-chat
AI_SUPPORT_VISION=false
AI_FALLBACK_MOCK=true

# GPT 开放生图 · 思考模式（留空则复用上方 DeepSeek）
GPT_OPEN_CHAT_URL=https://api.deepseek.com
GPT_OPEN_CHAT_API_KEY=
GPT_OPEN_CHAT_MODEL=deepseek-chat

# ---------- 生图网关 apimart（批量生图 + GPT 开放生图）----------
IMAGE_GEN_API_BASE_URL=https://api.apimart.ai
IMAGE_GEN_API_KEY=sk-你的apimart密钥
API_BASE_URL=https://api.apimart.ai
API_KEY=sk-你的apimart密钥

