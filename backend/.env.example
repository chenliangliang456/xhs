# DeepSeek AI 文案配置
AI_API_URL=https://api.deepseek.com/v1/chat/completions
AI_API_KEY=sk-在此填入你的DeepSeek密钥
AI_API_MODEL=deepseek-chat
AI_SUPPORT_VISION=false
AI_API_HEADERS={}
# API 失败时自动用本地模拟文案（false=直接报错）
AI_FALLBACK_MOCK=true
# 强制只用模拟文案，不调用 API
# AI_FORCE_MOCK=false

PORT=3002
JWT_SECRET=your-jwt-secret-change-me
ENCRYPT_KEY=your-encrypt-key-32chars-min!!

# 发布模式：browser（默认，扫码 Cookie 自动发帖）| api | mock
XHS_PUBLISH_MODE=browser
XHS_PUBLISH_URL=
XHS_UPLOAD_URL=
XHS_BROWSER_HEADLESS=true

PUBLISH_INTERVAL=3000
PUBLISH_RETRY_COUNT=2
PUBLISH_CONCURRENCY=1

# ---------- AI 批量文生图（gpt-image-2）----------
# 必填：文生图 API 的 Base URL 和 Key，填写后重启 backend
IMAGE_GEN_API_BASE_URL=https://你的API网关地址
IMAGE_GEN_API_KEY=你的API密钥
# 也支持旧变量名（与上面二选一）：
# API_BASE_URL=
# API_KEY=
